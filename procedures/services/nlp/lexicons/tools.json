  "instrumental_prepositions": {
    "_comment": "Prépositions qui, suivies d'un NOUN/PROPN, indiquent un outil/support. Score de confiance variable : 'via' et 'sur' sont très fiables, 'dans' et 'avec' plus ambigus.",
    "high_confidence": ["via", "par l'intermédiaire de", "au moyen de", "à l'aide de"],
    "medium_confidence": ["sur", "dans", "avec", "par"],
    "exclusion_nouns": [
      "délai", "heure", "minute", "jour", "semaine", "mois", "année",
      "temps", "exemple", "cas", "ensemble", "cadre", "sujet", "papier"
    ]
  }
