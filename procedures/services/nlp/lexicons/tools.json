    "Teams":          ["teams"],
    "Slack":          ["slack"],
    "SAP":            ["sap"],
    "Sage":           ["sage"],
    "Odoo":           ["odoo"],
    "Salesforce":     ["salesforce"],
    "HubSpot":        ["hubspot"],
    "Jira":           ["jira"],
    "Gmail":          ["gmail"],
    "Google Drive":   ["google drive", "gdrive"],
    "SharePoint":     ["sharepoint"],
    "Notion":         ["notion"],
    "Trello":         ["trello"],
    "Asana":          ["asana"],
    "Monday":         ["monday"],
    "Zendesk":        ["zendesk"],
    "Email":          ["email", "mail", "e-mail", "courriel"],
    "Téléphone":      ["téléphone", "tel"],
    "PDF":            ["pdf"],
    "ERP":            ["erp"],
