# Template de variables d'environnement pour ProcessIntelligence.
# À copier en `.env` à la racine du projet, puis remplir avec les vraies valeurs.
# Ce fichier .env.example est committé pour documenter la config attendue.
# Le fichier .env (avec les vraies valeurs) ne doit JAMAIS être committé.


# ============================================================================
# Django
# ============================================================================

SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1


# ============================================================================
# Base de données (si non-SQLite en dev)
# ============================================================================

# DATABASE_URL=postgres://user:pass@host:5432/dbname


# ============================================================================
# LLM Parser — Anthropic Claude
# ============================================================================

# Clé API Anthropic. Obtenir sur https://console.anthropic.com/
# IMPORTANT : ne jamais committer cette clé dans Git.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kill switch global pour le LLM parser.
# - false : utilise spaCy partout (comportement par défaut, pas d'appel API)
# - true  : active le LLM pour les organisations Pro/Business
# Mettre à false en cas d'incident avec l'API Anthropic.
LLM_PARSER_ENABLED=false

# Identifiant du modèle Claude à utiliser pour les plans Pro.
# Les plans Business peuvent utiliser un modèle plus précis (voir plans.py).
# Tarifs approximatifs (USD par million de tokens, input/output) :
#   claude-haiku-4-5-20251001  : 1$ / 5$      (rapide, bon marché)
#   claude-sonnet-4-6          : 3$ / 15$     (plus précis)
#   claude-opus-4-7            : 15$ / 75$    (maximum qualité, cher)
LLM_PARSER_MODEL=claude-haiku-4-5-20251001
